  <widget type="group" version="3.0.0">
    <name>Acquisition</name>
    <x>688</x>
    <y>42</y>
    <width>540</width>
    <height>105</height>
    <style>1</style>
    <widget type="action_button" version="3.0.0">
      <name>StartButton</name>
      <actions>
        <action type="write_pv">
          <description>Continuous mode</description>
          <pv_name>$(P)cam1:ImageMode</pv_name>
          <value>2</value>
        </action>
        <action type="write_pv">
          <description>Start acquisition</description>
          <pv_name>$(P)cam1:Acquire</pv_name>
          <value>1</value>
        </action>
      </actions>
      <text>Start</text>
      <x>5</x>
      <y>22</y>
      <width>80</width>
      <tooltip>Start continuous acquisition</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>StopButton</name>
      <actions>
        <action type="write_pv">
          <description>Stop acquisition</description>
          <pv_name>$(P)cam1:Acquire</pv_name>
          <value>0</value>
        </action>
      </actions>
      <text>Stop</text>
      <x>90</x>
      <y>22</y>
      <width>80</width>
      <tooltip>Stop acquisition</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>TriggerButton</name>
      <actions>
        <action type="write_pv">
          <description>Single mode</description>
          <pv_name>$(P)cam1:ImageMode</pv_name>
          <value>0</value>
        </action>
        <action type="write_pv">
          <description>Fire</description>
          <pv_name>$(P)cam1:Acquire</pv_name>
          <value>1</value>
        </action>
        <action type="write_pv">
          <description>Restore continuous mode</description>
          <pv_name>$(P)cam1:ImageMode</pv_name>
          <value>2</value>
        </action>
      </actions>
      <text>Single</text>
      <x>175</x>
      <y>22</y>
      <width>80</width>
      <tooltip>Capture one frame</tooltip>
    </widget>
