<?xml version="1.0" encoding="UTF-8"?>
<!--
  VPCam Phoebus screen — standard-areaDetector contract (ad_ioc_base.py).

  Open with macro P set to the camera prefix INCLUDING trailing colon,
  e.g. P=VPCAM:02:  — defaults to VPCAM:01: when opened standalone.

  ROI semantics: MinX/MinY/SizeX/SizeY apply immediately on write (the
  driver clamps).  "Reset ROI" exploits the clamping: it writes offsets 0
  and oversized dimensions, which the driver clamps to the full sensor.
-->
<display version="2.0.0">
  <name>VPCam</name>
  <macros>
    <P>VPCAM:01:</P>
  </macros>
  <width>1250</width>
  <height>875</height>
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>VPCam Dashboard</text>
    <x>10</x>
    <y>8</y>
    <width>210</width>
    <height>26</height>
    <font>
      <font family="Liberation Sans" style="BOLD" size="16.0">
      </font>
    </font>
  </widget>
