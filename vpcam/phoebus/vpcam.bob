  </widget>
  <widget type="group" version="3.0.0">
    <name>Live Image</name>
    <x>10</x>
    <y>42</y>
    <width>668</width>
    <height>557</height>
    <style>1</style>
    <widget type="image" version="2.0.0">
      <name>CameraImage</name>
      <pv_name>$(P)image1:ArrayData</pv_name>
      <x>5</x>
      <y>20</y>
      <width>656</width>
      <height>480</height>
      <color_map>
        <name>GRAY</name>
      </color_map>
      <data_width>4608</data_width>
      <data_height>2592</data_height>
      <unsigned>true</unsigned>
      <rules>
        <!-- Rules trigger ONLY on the scalar dimension PVs, NOT on ArrayData.
             The IOC always writes ArraySize0/1_RBV BEFORE ArrayData in
             _publish_frame, so by the time the large waveform arrives these
             rules have already fired and data_width / data_height are set
             correctly.  Adding ArrayData as a trigger caused issues: on
             initial connection the large waveform arrives before the rules
             can fire from the small scalar PVs, causing a momentary
             dimension mismatch. -->
        <rule name="UpdateDataWidth" prop_id="data_width" out_exp="true">
          <exp bool_exp="true">
            <value>pvInt("$(P)image1:ArraySize0_RBV")</value>
          </exp>
          <pv_name>$(P)image1:ArraySize0_RBV</pv_name>
        </rule>
        <rule name="UpdateDataHeight" prop_id="data_height" out_exp="true">
          <exp bool_exp="true">
            <value>pvInt("$(P)image1:ArraySize1_RBV")</value>
          </exp>
          <pv_name>$(P)image1:ArraySize1_RBV</pv_name>
        </rule>
      </rules>
    </widget>
    <widget type="label" version="2.0.0">
      <text>Size:</text>
      <x>5</x>
      <y>510</y>
      <width>40</width>
      <height>18</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <pv_name>$(P)image1:ArraySize0_RBV</pv_name>
